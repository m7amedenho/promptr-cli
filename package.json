  },
  "keywords": [
    "prompt",
    "prompt-engineering",
    "llm",
    "ai",
    "cli",
    "developer-tool"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.64.0",
    "chalk": "^5.6.0",
    "commander": "^14.0.1",
    "ora": "^9.0.0"
  }
}
