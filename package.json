{
  "name": "promptr-cli",
  "version": "1.0.3",
  "description": "Offline-first prompt improvement CLI with optional LLM mode",
  "type": "module",
  "bin": {
    "promptr": "bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md"
  ],
  "main": "./src/engine.js",
  "exports": {
    ".": "./src/engine.js"
  },
  "scripts": {
